FROM node:22-bookworm-slim

WORKDIR /app

ARG NEXT_PUBLIC_EVOMATE_API_URL=https://evomate-api-3mkana4zma-df.a.run.app

ENV NODE_ENV=production \
    NEXT_PUBLIC_EVOMATE_API_URL=${NEXT_PUBLIC_EVOMATE_API_URL} \
    EVOMATE_PROJECT_ROOT=/app

COPY package.json package-lock.json tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts

RUN npm ci --include=dev
RUN npm run build -w apps/web

EXPOSE 8080

CMD ["sh", "-lc", "EVOMATE_WEB_PORT=${PORT:-8080} npm run start -w apps/web"]
