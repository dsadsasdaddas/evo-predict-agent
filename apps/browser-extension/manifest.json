{
  "manifest_version": 3,
  "name": "EvoMate Web Hook",
  "version": "0.1.0",
  "description": "Auto-observe AI web chats and send evolution signals to EvoMate Hook Protocol.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://evomate.yueanlab.com/*",
    "https://evomate-api-3mkana4zma-df.a.run.app/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "action": {
    "default_title": "EvoMate Web Hook",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*",
        "https://aistudio.google.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Capture selected text into EvoMate"
    }
  }
}
